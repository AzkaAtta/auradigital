---

<DefaultLayout title={title} description={description} keywords={keywords}>

<Fragment slot="head">
<script type="application/ld+json">
[
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": "Jasa Komentar Instagram Aktif & Custom Teks",
    "image": "https://auradigital.id/image/paket-harga-komentarig.png",
    "description": "Layanan jasa komentar instagram yang aman dan bebas custom teks. Bikin konten IG makin hidup dan raih rasa percaya pelanggan bersama AuraDigital.",
    "brand": {
      "@type": "Brand",
      "name": "auradigital"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "worstRating": "1",
      "ratingCount": "980"
    },
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "200000",
      "highPrice": "2000000",
      "priceCurrency": "IDR",
      "offerCount": "2"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
