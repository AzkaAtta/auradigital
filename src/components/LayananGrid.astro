---
// src/components/LayananGrid.astro
import { Icon } from 'astro-icon/components';

// Data Layanan Kita Kelompokkan Berdasarkan Platform biar rapi!
const layananKategori = [
  {
    platform: "Instagram",
    icon: "lucide:instagram",
    color: "from-pink-500 to-violet-500",
    services: [
      { nama: "Followers", link: "/like-instagram/" },
      { nama: "Likes", link: "/like-instagram/" },
      { nama: "Views (Reels/Video)", link: "/like-instagram/" },
      { nama: "Comments", link: "/like-komentar-instagram/" },
      { nama: "Likes Comment", link: "/like-instagram/" },
      { nama: "Saves", link: "/like-instagram/" },
      { nama: "Shares", link: "/like-instagram/" },
      { nama: "Repost to Story", link: "/like-instagram/" },
    ]
  },
  {
    platform: "TikTok",
    icon: "lucide:music-2",
    color: "from-slate-400 to-slate-100",
    services: [
      { nama: "Followers", link: "/like-tiktok/" },
      { nama: "Likes", link: "/like-tiktok/" },
      { nama: "Views", link: "/like-tiktok/" },
      { nama: "Comments", link: "/like-komentar-tiktok/" },
      { nama: "Shares", link: "/like-tiktok/" },
      { nama: "Saves", link: "/like-tiktok/" },
    ]
  },
  {
    platform: "Facebook",
    icon: "lucide:facebook",
    color: "from-blue-500 to-blue-700",
    services: [
      { nama: "Page Likes/Followers", link: "/like-facebook/" },
      { nama: "Post Likes", link: "/like-facebook/" },
      { nama: "Comments", link: "/like-komentar-facebook/" },
      { nama: "Video Views", link: "/like-facebook/" },
      { nama: "Shares", link: "/like-facebook/" },
    ]
  },
  {
    platform: "Twitter / X",
    icon: "lucide:twitter",
    color: "from-slate-300 to-slate-500",
    services: [
      { nama: "Followers", link: "/like-twitter/" },
      { nama: "Likes", link: "/like-twitter/" },
      { nama: "Retweets", link: "/like-twitter/" },
      { nama: "Comments/Replies", link: "/like-komentar-twitter/" },
      { nama: "Views", link: "/like-twitter/" },
    ]
  }
];
---

<section class="py-24 bg-[#090514] relative overflow-hidden border-t border-violet-900/30">
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[500px] h-[500px] bg-violet-700/10 blur-[120px] rounded-full pointer-events-none z-0"></div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 reveal-up">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Eskalasi Lengkap untuk Setiap Platform</h2>
      <p class="text-slate-400">Pilih platform target Anda dan temukan layanan spesifik yang dirancang khusus untuk memanipulasi algoritma secara positif dan organik.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {layananKategori.map((kategori) => (
        <div class="bg-[#0F0A21] border border-violet-900/30 rounded-2xl p-6 md:p-8 hover:border-violet-500/50 transition-colors duration-300 shadow-lg shadow-violet-900/10 group reveal-up">
          
          <div class="flex items-center gap-4 mb-6 pb-6 border-b border-violet-900/30">
            <div class={`w-12 h-12 rounded-xl flex items-center justify-center bg-gradient-to-br ${kategori.color} text-slate-900 shadow-md`}>
              <Icon name={kategori.icon} class="w-6 h-6 text-white mix-blend-difference" />
            </div>
            <h3 class="text-2xl font-bold text-white">{kategori.platform}</h3>
          </div>

          <div class="flex flex-wrap gap-3">
            {kategori.services.map((service) => (
              <a 
                href={service.link} 
                class="inline-flex items-center text-sm font-medium text-slate-300 bg-violet-900/20 border border-violet-800/50 px-4 py-2 rounded-lg hover:bg-violet-600 hover:text-white hover:border-violet-500 transition-all duration-200 !no-underline"
              >
                {service.nama}
              </a>
            ))}
          </div>
          
        </div>
      ))}
    </div>
  </div>
</section>